{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.(css|js|svg|png|jpg|jpeg|gif|webp|ico|woff|woff2|ttf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/blog-5x-capacity", "destination": "/blog-5x-capacity.html" },
    { "source": "/blog-ifrs-smes", "destination": "/blog-ifrs-smes.html" },
    { "source": "/blog-sme-market", "destination": "/blog-sme-market.html" },
    { "source": "/blog-tax-reforms", "destination": "/blog-tax-reforms.html" },
    { "source": "/cookie-policy", "destination": "/cookie-policy.html" },
    { "source": "/how-it-works", "destination": "/how-it-works.html" },
    { "source": "/opportunity", "destination": "/opportunity.html" },
    { "source": "/outputs", "destination": "/outputs.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/privacy-policy", "destination": "/privacy-policy.html" },
    { "source": "/security", "destination": "/security.html" },
    { "source": "/terms-of-service", "destination": "/terms-of-service.html" }
  ]
}